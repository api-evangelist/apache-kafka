{
  "type": "object",
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/apache-kafka/refs/heads/main/json-structure/kafka-rest-proxy-consumer-group-structure.json",
  "name": "ConsumerGroup",
  "description": "ConsumerGroup schema from Apache kafka",
  "properties": {
    "kind": {
      "type": "string"
    },
    "metadata": {
      "type": "object"
    },
    "cluster_id": {
      "type": "string"
    },
    "consumer_group_id": {
      "type": "string"
    },
    "is_simple": {
      "type": "boolean"
    },
    "partition_assignor": {
      "type": "string"
    },
    "state": {
      "type": "string",
      "enum": [
        "UNKNOWN",
        "PREPARING_REBALANCE",
        "COMPLETING_REBALANCE",
        "STABLE",
        "DEAD",
        "EMPTY"
      ]
    },
    "coordinator": {
      "type": "object"
    },
    "consumers": {
      "type": "object"
    },
    "lag_summary": {
      "type": "object"
    }
  }
}